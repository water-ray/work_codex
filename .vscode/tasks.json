{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "仓库：查看当前分支",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "status"
      ],
      "windows": {
        "command": "py",
        "args": [
          "-3",
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "status"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "显示当前分支、上游、远程仓库和作者信息。"
    },
    {
      "label": "仓库：切换/创建分支",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "switch",
        "--branch",
        "${input:repoBranchName}",
        "--remote",
        "${input:repoSwitchRemoteName}"
      ],
      "windows": {
        "command": "py",
        "args": [
          "-3",
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "switch",
          "--branch",
          "${input:repoBranchName}",
          "--remote",
          "${input:repoSwitchRemoteName}"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "输入分支名称和远程源；本地存在则切换，本地不存在但远程存在则跟踪远程分支并拉取，两者都不存在则创建新本地分支。"
    },
    {
      "label": "仓库：提交当前改动",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "commit",
        "--message",
        "${input:repoCommitMessage}"
      ],
      "windows": {
        "command": "py",
        "args": [
          "-3",
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "commit",
          "--message",
          "${input:repoCommitMessage}"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "输入提交说明后，自动暂存并提交当前全部改动。 "
    },
    {
      "label": "仓库：推送当前分支",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "push-current",
        "--remote",
        "${input:repoPushCurrentRemoteName}"
      ],
      "windows": {
        "command": "py",
        "args": [
          "-3",
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "push-current",
          "--remote",
          "${input:repoPushCurrentRemoteName}"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "输入远程源；留空时复用“推送当前分支”任务缓存或回退到当前上游/ origin。若遇到非 fast-forward，可在终端输入 Y/yes 强推。"
    },
    {
      "label": "仓库：推送指定分支",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "push-branch",
        "--remote",
        "${input:repoPushBranchRemoteName}",
        "--branch",
        "${input:repoPushBranchTargetBranch}"
      ],
      "windows": {
        "command": "py",
        "args": [
          "-3",
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "push-branch",
          "--remote",
          "${input:repoPushBranchRemoteName}",
          "--branch",
          "${input:repoPushBranchTargetBranch}"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "输入远程源和目标分支；留空时优先复用“推送指定分支”任务缓存。若遇到非 fast-forward，可在终端输入 Y/yes 强推。"
    },
    {
      "label": "仓库：拉取远程分支",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "pull-remote",
        "--remote",
        "${input:repoPullRemoteRemoteName}",
        "--branch",
        "${input:repoPullRemoteBranchName}"
      ],
      "windows": {
        "command": "py",
        "args": [
          "-3",
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "pull-remote",
          "--remote",
          "${input:repoPullRemoteRemoteName}",
          "--branch",
          "${input:repoPullRemoteBranchName}"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "输入远程源和远程分支；先自动提交本地改动，再检查远程分支，同名分支优先合并，冲突或分支不同则确认后覆盖拉取。"
    },
    {
      "label": "仓库：设置远程仓库源",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "set-remote",
        "--name",
        "${input:repoRemoteSetName}",
        "--url",
        "${input:repoRemoteSetUrl}"
      ],
      "windows": {
        "command": "py",
        "args": [
          "-3",
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "set-remote",
          "--name",
          "${input:repoRemoteSetName}",
          "--url",
          "${input:repoRemoteSetUrl}"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "输入远程源名称与地址；不存在则新增，已存在则更新绑定。"
    }
  ],
  "inputs": [
    {
      "id": "repoBranchName",
      "type": "promptString",
      "description": "输入分支名称；本地存在则切换，本地不存在但远程存在则跟踪远程分支并拉取，两者都不存在则创建新本地分支。"
    },
    {
      "id": "repoSwitchRemoteName",
      "type": "promptString",
      "description": "输入切换/创建分支时检查的远程源名称；留空时使用该任务缓存，缓存不存在时回退到当前上游或 origin。"
    },
    {
      "id": "repoCommitMessage",
      "type": "promptString",
      "description": "输入提交说明；任务会自动提交当前全部改动。"
    },
    {
      "id": "repoPushCurrentRemoteName",
      "type": "promptString",
      "description": "输入推送当前分支使用的远程源名称；留空时使用该任务缓存，缓存不存在时回退到当前上游或 origin。"
    },
    {
      "id": "repoPushBranchRemoteName",
      "type": "promptString",
      "description": "输入推送指定分支使用的远程源名称；留空时使用该任务缓存，缓存不存在时回退到当前上游或 origin。"
    },
    {
      "id": "repoPushBranchTargetBranch",
      "type": "promptString",
      "description": "输入推送指定分支的目标远程分支；留空时使用该任务缓存，缓存不存在时使用当前分支。"
    },
    {
      "id": "repoPullRemoteRemoteName",
      "type": "promptString",
      "description": "输入要拉取的远程源名称，例如 origin。"
    },
    {
      "id": "repoPullRemoteBranchName",
      "type": "promptString",
      "description": "输入要拉取的远程分支名称，例如 main 或 feature/demo。"
    },
    {
      "id": "repoRemoteSetName",
      "type": "promptString",
      "description": "输入远程源名称，例如 origin。"
    },
    {
      "id": "repoRemoteSetUrl",
      "type": "promptString",
      "description": "输入远程仓库地址，例如 https://github.com/user/repo.git。"
    }
  ]
}
