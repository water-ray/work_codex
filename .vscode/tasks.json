{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "仓库：查看当前分支",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "status"
      ],
      "windows": {
        "command": "py",
        "args": [
          "-3",
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "status"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "按固定标签显示本地分支、远程分支、fetch/push 地址和作者信息；用于查看当前仓库设置。"
    },
    {
      "label": "仓库：设置远程仓库源",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "set-remote"
      ],
      "windows": {
        "command": "py",
        "args": [
          "-3",
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "set-remote"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "在终端输入远程源名称与地址；不存在则新增，已存在则更新绑定，并设置为当前仓库默认远程源。"
    },
    {
      "label": "仓库：拉取远程分支",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "pull-remote"
      ],
      "windows": {
        "command": "py",
        "args": [
          "-3",
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "pull-remote"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "在终端输入远程分支；未设置远程源时提示先设置。先自动提交本地改动，同名分支优先合并，失败或分支不同则确认后覆盖拉取。"
    },
    {
      "label": "仓库：切换/创建分支",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "switch"
      ],
      "windows": {
        "command": "py",
        "args": [
          "-3",
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "switch"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "在终端输入分支名称； 切换前自动提交当前改动。远程分支存在时优先切换/同步远程分支，未设置远程源或远程分支不存在时仅处理本地分支。"
    },
    {
      "label": "仓库：提交当前改动",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "commit"
      ],
      "windows": {
        "command": "py",
        "args": [
          "-3",
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "commit"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "先显示上次提交、本次改动和规则生成的中文默认提交说明；直接回车使用默认说明，手动输入则使用输入内容提交。"
    },
    {
      "label": "仓库：推送分支",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "push"
      ],
      "windows": {
        "command": "py",
        "args": [
          "-3",
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "push"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "在终端输入目标远程分支，默认当前分支；未设置远程源时提示先设置。远程分支不存在则创建，已存在则普通推送，失败时显示差异并确认是否强推。"
    }
  ]
}
