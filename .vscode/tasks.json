{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "仓库：分支-[查看] 🔎",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "status"
      ],
      "windows": {
        "command": "python",
        "args": [
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "status"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "按固定标签显示本地分支、远程分支、fetch/push 地址和作者信息；用于查看当前仓库设置。"
    },
    {
      "label": "仓库：置远程源 🔗",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "set-remote"
      ],
      "windows": {
        "command": "python",
        "args": [
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "set-remote"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "在终端输入远程源名称与地址；不存在则新增，已存在则更新绑定，并设置为当前仓库默认远程源。"
    },
    {
      "label": "仓库：远程-[拉取] ⬇️",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "pull-remote"
      ],
      "windows": {
        "command": "python",
        "args": [
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "pull-remote"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "在终端输入远程分支；未设置远程源时提示先设置。先自动提交本地改动，同名分支优先合并，失败或分支不同则确认后覆盖拉取。"
    },
    {
      "label": "仓库：本地-[切换] 🌿",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "switch"
      ],
      "windows": {
        "command": "python",
        "args": [
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "switch"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "有远程源时先列出远程分支，无远程源时列出本地分支；输入编号选择分支，输入文本作为分支名。切换前自动提交当前改动。"
    },
    {
      "label": "仓库：本地-[提交] 📝",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "commit"
      ],
      "windows": {
        "command": "python",
        "args": [
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "commit"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "先显示上次提交、本次改动和规则生成的中文默认提交说明；直接回车使用默认说明，手动输入则使用输入内容提交。"
    },
    {
      "label": "仓库：远程-[推送] 🚀",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "push"
      ],
      "windows": {
        "command": "python",
        "args": [
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "push"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "先列出远程分支并编号；输入编号选择远程分支，输入文本作为目标分支，直接回车使用当前分支。远程分支不存在则创建，推送失败时显示差异并确认是否强推。"
    },
    {
      "label": "仓库：本地-[还原] ↩️",
      "type": "process",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/git/repo_tasks.py",
        "restore-node"
      ],
      "windows": {
        "command": "python",
        "args": [
          "${workspaceFolder}/scripts/git/repo_tasks.py",
          "restore-node"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "detail": "倒序分页列出最近提交点；输入编号并二次确认后执行 git reset --hard 还原到目标节点，直接回车取消。"
    }
  ]
}
